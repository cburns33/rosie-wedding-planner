ANTHROPIC_API_KEY=

# Project URL only — no /rest/v1 suffix
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Settings → API in Supabase dashboard
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# legacy name also supported:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Comma-separated emails allowed to sign in
ALLOWED_EMAILS=kelsie@example.com,hank@example.com

# Optional — local dev only (ignored in production). Bypasses magic-link auth.
# DISABLE_AUTH=true

# Sentry — project: talos-advisory/javascript-nextjs
# DSN: Settings → Projects → javascript-nextjs → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Build-time source map upload: https://sentry.io/settings/auth-tokens/ (project:releases + org:read)
# SENTRY_AUTH_TOKEN=
